#!/bin/sh /etc/rc.common
# Separate sing-box instance: subscription load-balancer feeding a local SOCKS.
# Config lives in RAM (/tmp); regenerated here on every (re)start.
START=95
STOP=10
USE_PROCD=1
CFG=/tmp/oxid/config.json
GEN=/etc/oxid/gen.py
LOG=/tmp/oxid/gen.log

start_service() {
    mkdir -p /tmp/oxid                 # tmpfs is empty after every reboot
    /usr/bin/python3 "$GEN" > "$LOG" 2>&1
    # boot safety net: if generation ever fails, fall back to last-known-good
    if ! /usr/bin/sing-box-awg check -c "$CFG" 2>/dev/null; then
        [ -f /etc/oxid/config.last ] && cp /etc/oxid/config.last "$CFG"
    fi
    procd_open_instance
    procd_set_param command /usr/bin/sing-box-awg run -c "$CFG"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param limits nofile="65535 65535"
    procd_close_instance
    # once the network is up, pull fresh subs into RAM without a restart — but ONLY
    # when hourly refresh is enabled. Gate BEFORE the sleep (so an opt-out restart
    # spawns nothing) and fully detach (</dev/null) so it never pins a caller's
    # SSH/exec channel open for 90s. Every apply restarts the core, so this must
    # not linger.
    if [ "$(uci -q get oxid.main.hourly)" != "0" ]; then
        ( sleep 90; /etc/oxid/oxid 'stage!' ) </dev/null >/dev/null 2>&1 &
    fi
}

reload_service() {
    mkdir -p /tmp/oxid
    /usr/bin/python3 "$GEN" > "$LOG" 2>&1
    if /usr/bin/sing-box-awg check -c "$CFG"; then
        restart
    else
        echo "generated config invalid — keeping running instance" >&2
        return 1
    fi
}
