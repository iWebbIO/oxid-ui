#!/bin/sh
# oxid control surface — used by cron and the LuCI app.
ETC=/etc/oxid
STATIC=$ETC/static
CFG=/tmp/oxid/config.json
BIN=/usr/bin/sing-box-awg
GEN="python3 $ETC/gen.py"

mkdir -p /tmp/oxid   # tmpfs is wiped on reboot; every path below needs it

secret() { uci -q get oxid.main.secret; }
api() { # api METHOD PATH [DATA]
    local m="$1" p="$2" d="$3"
    if [ -n "$d" ]; then
        curl -m6 -sS -X "$m" -H "Authorization: Bearer $(secret)" \
             -H 'Content-Type: application/json' -d "$d" "http://127.0.0.1:9090$p"
    else
        curl -m6 -sS -X "$m" -H "Authorization: Bearer $(secret)" "http://127.0.0.1:9090$p"
    fi
}

stage() {  # graceful: rebuild RAM config, validate, DO NOT restart
    $GEN 2>>/tmp/oxid/gen.log
    if $BIN check -c "$CFG"; then
        cmp -s "$CFG" "$ETC/config.last" 2>/dev/null || cp "$CFG" "$ETC/config.last"  # boot safety net
        echo "staged"
    else echo "ERR invalid config; kept previous"; return 1; fi
}

member() { # resolve a bare tag (sub name / static / direct) to its selector member
    local t="$1"; uci -q show oxid | grep -q "\.name='$t'" && echo "sub:$t" || echo "$t"
}
healthy() { # healthy <selector-member> -> 0 if a health probe through it succeeds
    # own curl with a longer -m than api() (idle AmneziaWG needs time to handshake)
    curl -m12 -sS -H "Authorization: Bearer $(secret)" \
        "http://127.0.0.1:9090/proxies/$1/delay?url=http://www.gstatic.com/generate_204&timeout=8000" \
        2>/dev/null | grep -q '"delay"'
}
watchdog() { # keep the main outbound preferred; fail over to a working sub if it dies
    [ "$(uci -q get oxid.main.watchdog)" = "0" ] && return 0
    pgrep -f "sing-box-awg run -c $CFG" >/dev/null || return 0
    local main cur; main=$(uci -q get oxid.main.active); [ -n "$main" ] || return 0
    main=$(member "$main")
    cur=$(api GET /proxies/PROXY 2>/dev/null | python3 -c "import sys,json;print(json.load(sys.stdin).get('now',''))" 2>/dev/null)
    if healthy "$main"; then
        [ "$cur" != "$main" ] && { api PUT /proxies/PROXY "{\"name\":\"$main\"}" >/dev/null; logger -t oxid "watchdog: restored $main"; }
    elif ! healthy "$cur"; then
        for g in $(python3 -c "import json;print(' '.join(o['tag'] for o in json.load(open('$CFG'))['outbounds'] if o.get('tag','').startswith('sub:')))" 2>/dev/null); do
            if healthy "$g"; then api PUT /proxies/PROXY "{\"name\":\"$g\"}" >/dev/null; logger -t oxid "watchdog: $main down, failover to $g"; break; fi
        done
    fi
}
apply() {  # rebuild + validate + restart (loads fresh nodes into the core)
    $GEN 2>>/tmp/oxid/gen.log
    if $BIN check -c "$CFG"; then
        /etc/init.d/oxid restart
        # re-assert active outbound (cache_file may restore a stale selection)
        local t; t=$(uci -q get oxid.main.active)
        [ -n "$t" ] && { i=0; while [ $i -lt 10 ]; do api GET /version >/dev/null 2>&1 && break; sleep 1; i=$((i+1)); done; switch "$t" >/dev/null 2>&1; }
        echo "applied"
    else echo "ERR invalid; not applied"; return 1; fi
}
switch() { # switch active outbound live (no restart) + persist to UCI
    local tag="$1"; [ -n "$tag" ] || { echo "usage: switch <tag>"; return 1; }
    # persist: store bare name (sub name / static tag / direct)
    uci set oxid.main.active="$tag"; uci commit oxid
    # resolve to selector member: sub name -> sub:<name>
    local member="$tag"
    uci -q show oxid | grep -q "\.name='$tag'" && member="sub:$tag"
    api PUT /proxies/PROXY "{\"name\":\"$member\"}" >/dev/null && echo "switched to $member" || echo "ERR switch"
}
status() { # JSON status for the GUI (config + live clash-api data)
    local up=0; pgrep -f "sing-box-awg run -c $CFG" >/dev/null && up=1
    UP="$up" SECRET="$(secret)" ABARE="$(uci -q get oxid.main.active)" \
    PORT="$(uci -q get oxid.main.socks_port || echo 7890)" \
    CTRL="$(uci -q get oxid.main.controller || echo 0.0.0.0:9090)" \
    PROXIES="$(api GET /proxies 2>/dev/null)" VER="$(api GET /version 2>/dev/null)" \
    python3 - <<PY 2>/dev/null
import json,os
def j(e):
    try: return json.loads(os.environ.get(e,"") or "{}")
    except: return {}
up=os.environ.get("UP","0")=="1"
prox=j("PROXIES").get("proxies",{})
now=prox.get("PROXY",{}).get("now","")
ver=j("VER").get("version","")
cfg={}
try: cfg=json.load(open("$CFG"))
except: pass
obs=cfg.get("outbounds",[]); by={o.get("tag"):o for o in obs}
subs=[o["tag"] for o in obs if o.get("tag","").startswith("sub:")]
subnames={t[4:] for t in subs}
def resolve(m):
    m=(m or "").strip()
    if m in ("direct","block") or not m: return m
    if ":" in m:
        pre,rest=m.split(":",1)
        return {"sub":"sub:"+rest,"node":"node:"+rest,"group":"grp:"+rest,
                "chain":"chain:"+rest,"static":rest}.get(pre, m)
    return ("sub:"+m) if m in subnames else m
main=resolve(os.environ.get("ABARE",""))
grps=[o["tag"] for o in obs if o.get("tag","").startswith("grp:")]
chains=[o["tag"] for o in obs if o.get("tag","").startswith("chain:") and ":h" not in o["tag"]]
eps=[e["tag"] for e in cfg.get("endpoints",[])]
counts={t:len(by[t].get("outbounds",[])) for t in subs}
def delay(t):
    h=prox.get(t,{}).get("history",[]); return h[-1]["delay"] if h else 0
delays={t:delay(t) for t in subs+grps+chains}; delays[now]=delay(now)
def path(tag):
    seq=[]; seen=set(); cur=tag
    while cur and cur not in seen:
        seen.add(cur); seq.append(cur); cur=by.get(cur,{}).get("detour")
    seq.reverse(); return seq
statics=[]
d="$STATIC"
if os.path.isdir(d):
    for f in sorted(os.listdir(d)):
        if not f.endswith(".json"): continue
        try:
            o=json.load(open(d+"/"+f)); statics.append({"tag":o.get("tag",f[:-5]),"type":o.get("type","")})
        except: statics.append({"tag":f[:-5],"type":"?"})
print(json.dumps({"running":up,"active":now,"main":main,"version":ver,
    "subs":subs,"groups":grps,"chains":chains,"endpoints":eps,
    "counts":counts,"delays":delays,"path":path(now),"statics":statics,
    "secret":os.environ.get("SECRET",""),
    "clash_port":os.environ.get("CTRL","0.0.0.0:9090").split(":")[-1],
    "socks_port":os.environ.get("PORT","7890")}))
PY
}
delay() { # delay <tag> [url] -> {"tag","ms"} | {"tag","error"} via clash-api probe
    # measures latency THROUGH <tag> to <url>. Handles unicode/':' tags (sub member
    # nodes are "name│orig") by percent-encoding the path segment. Probes TWICE and
    # keeps the lower — the first probe pays the cold handshake (AmneziaWG's idle
    # handshake alone is ~5s), the second reflects the real steady-state latency.
    TAG="$1" URL="${2:-http://www.gstatic.com/generate_204}" SEC="$(secret)" python3 - <<'PY'
import os,subprocess,json
def q(s):
    o=[]
    for by in s.encode("utf-8"):
        c=chr(by)
        o.append(c if (c.isalnum() or c in "-_.~:") else "%%%02X"%by)
    return "".join(o)
tag=os.environ["TAG"]; url=os.environ["URL"]; sec=os.environ["SEC"]
u="http://127.0.0.1:9090/proxies/%s/delay?url=%s&timeout=8000"%(q(tag),q(url))
def probe():
    try:
        r=subprocess.check_output(["curl","-m","12","-sS","-H","Authorization: Bearer "+sec,u],
                                  stderr=subprocess.DEVNULL).decode("utf-8","replace")
        d=json.loads(r); return d.get("delay") if "delay" in d else None
    except Exception:
        return None
best=None
for i in range(2):
    ms=probe()
    if ms is None: break               # dead/timeout -> don't waste a 2nd 8s probe
    best=ms if best is None else min(best,ms)
    if best<800: break                 # already good; only re-probe to warm a slow-but-alive node
print(json.dumps({"tag":tag,"ms":best} if best is not None else {"tag":tag,"error":"timeout"}))
PY
}
conntest() { # {"ip","ms"} through the proxy
    local p; p=$(uci -q get oxid.main.socks_port || echo 7890)
    local r ip t; r=$(curl -m15 -sS -w '\n%{time_total}' --socks5-hostname "127.0.0.1:$p" https://api.ipify.org 2>/dev/null)
    ip=$(printf '%s' "$r" | head -1); t=$(printf '%s' "$r" | tail -1)
    [ -n "$ip" ] && [ "$ip" != "$t" ] && echo "{\"ip\":\"$ip\",\"ms\":$(awk "BEGIN{printf \"%d\",$t*1000}")}" || echo '{"ip":"","ms":0}'
}
mutate() { # run a UCI edit (reads JSON on stdin), then load it into the core.
    # Subs are unchanged by a node/chain/group edit, so regen OFFLINE (disk cache,
    # no ~25s GitHub refetch); the marker makes both apply's gen AND the restart's
    # init-gen fast. Cleared afterwards so hourly/boot still refresh from network.
    local out; out=$(python3 "$ETC/edit.py" "$1")
    if echo "$out" | grep -q '"ok": true'; then
        touch /tmp/oxid/offline
        apply >/dev/null 2>&1
        rm -f /tmp/oxid/offline
        echo "$out"
    else
        echo "$out"; return 1
    fi
}
case "$1" in
    stage)   [ "$(uci -q get oxid.main.hourly)" = "0" ] && { echo "hourly disabled"; exit 0; }; stage ;;
    config)  python3 "$ETC/edit.py" dump ;;   # typed model as JSON (manager read side)
    tags)    python3 "$ETC/edit.py" tags ;;   # testable outbound tree (Test page)
    delay)   delay "$2" "$3" ;;               # latency of <tag> to <url> via clash-api
    sub-add|sub-del|sub-toggle|node-set|node-del|group-set|group-del|chain-set|chain-del)
        mutate "$1" ;;                          # JSON body on stdin -> edit + apply
    stage!)  stage ;;                       # force stage regardless of hourly flag
    apply)   apply ;;
    restart) /etc/init.d/oxid restart; echo restarted ;;
    switch)  switch "$2" ;;
    watchdog) watchdog ;;
    status)  status ;;
    test)    conntest ;;
    self-update)        "$ETC/oxid-update.sh" ;;          # update panel from GitHub, no core restart
    self-update-apply)  "$ETC/oxid-update.sh" --apply ;;  # update + restart core (the button's arrow)
    static-del)  rm -f "$STATIC/$2.json" && stage; echo "deleted $2" ;;
    awg-import)  # awg-import <tag>  (wg-quick on stdin)
        mkdir -p "$STATIC"
        if ! python3 "$ETC/awg2singbox.py" "$2" > "$STATIC/$2.json"; then
            rm -f "$STATIC/$2.json"; echo "ERR awg parse (need [Interface] PrivateKey + [Peer] PublicKey/Endpoint)"; exit 1; fi
        if stage | grep -q staged; then echo "imported $2"; else rm -f "$STATIC/$2.json"; stage >/dev/null; echo "ERR node rejected by sing-box; removed"; exit 1; fi ;;
    static-add)  # static-add <tag>  (raw sing-box outbound/endpoint JSON on stdin)
        mkdir -p "$STATIC"; cat > "$STATIC/$2.json"
        if ! python3 -c "import json,sys;o=json.load(open('$STATIC/$2.json'));sys.exit(0 if o.get('tag') and o.get('type') else 1)" 2>/dev/null; then
            rm -f "$STATIC/$2.json"; echo "ERR JSON must have tag+type"; exit 1; fi
        if stage | grep -q staged; then echo "added $2"; else rm -f "$STATIC/$2.json"; stage >/dev/null; echo "ERR node rejected by sing-box; removed"; exit 1; fi ;;
    *) echo "usage: oxid {stage|apply|restart|switch <tag>|status|config|watchdog|self-update|self-update-apply|static-del <n>|awg-import <n>|static-add <n>|{sub,node,group,chain}-* (JSON on stdin)}" ;;
esac
